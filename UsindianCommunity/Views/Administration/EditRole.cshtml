@model EditRoleViewModel
@{
    ViewBag.Title = "Edit USer Role";
    ViewBag.Area = ViewBag.Area;
}
<div class="row">
    <div class="mb-5  col-md-2 d-none d-md-block">
        <main role="main">

        </main>
    </div>

    <div class="container border border-dark p-3 mb-5 col-md-8">


        <h1>Edit Role</h1>

        <form method="post" class="mt-3">
            <div class="form-group row">
                <label asp-for="Id" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                    <input asp-for="Id" disabled class="form-control">
                </div>
            </div>
            <div class="form-group row">
                <label asp-for="RoleName" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                    <input asp-for="RoleName" class="form-control">
                    <span asp-validation-for="RoleName" class="text-danger"></span>
                </div>
            </div>

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group row">
                <div class="col-sm-10">
                    <button type="submit" class="btn btn-primary">Update</button>
                    <a asp-area="" asp-action="ManageRole" asp-controller="Administration"  asp-route-AreaName=@ViewBag.Area class="btn btn-primary">Back</a>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3>Users in this role</h3>
                </div>
                <div class="card-body">
                    @if (Model.Users.Any())
                    {
                        foreach (var user in Model.Users)
                        {
                            <h5 class="card-title">@user</h5>
                        }
                    }
                    else
                    {
                        <h5 class="card-title">None at the moment</h5>
                    }
                </div>
                <div class="card-footer">
                    <a asp-area="" asp-action="ManageUserInRole" asp-controller="Administration" asp-route-id="@Model.Id" asp-route-AreaName=@ViewBag.Area class="btn btn-primary" style="width:auto">Add Or Remove Users</a>
                </div>
            </div>
        </form>
    </div>
    <div class="mb-5  col-md-2 d-none d-md-block">
        <main role="main">

        </main>
    </div>
</div>