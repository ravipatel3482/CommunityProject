@model IEnumerable<IdentityRole>
@{
    ViewBag.Title = "Manage Role";
    ViewBag.Area = ViewBag.Area;
    TempData["Area"] = ViewBag.Area;
 }
<div class="row">
    <div class="col-lg-2">
    </div>
    <div class=" container col-lg-8">
        <h1>All Roles</h1>
        @if (Model.Any())
        {
            <a class="btn btn-primary mb-3" style="width:auto" asp-area="" asp-action="CreateRole"
               asp-controller="Administration" asp-route-AreaName=@ViewBag.Area>Add new role</a>

            foreach (var role in Model)
            {
                <div class="card">
                    <div class="card-header">
                        Role Id : @role.Id
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@role.Name</h5>
                    </div>
                    <div class="card-footer">

                        <form asp-action="DeleteRole" asp-route-id="@role.Id" asp-controller="Administration" method="post" asp-route-AreaName="@ViewBag.Area">
                            <a class="btn btn-primary" style="width:auto" asp-area="" asp-controller="Administration" asp-action="EditRole" asp-route-id=@role.Id asp-route-AreaName=@ViewBag.Area>Edit Role</a>

                            <span id="confirmDeleteSpan_@role.Id" style="display:none">
                                <span>Are you sure you want to delete?</span>
                                <button type="submit" class="btn btn-danger">Yes</button>
                                <span class="btn btn-primary"
                                   onclick="confirmDelete('@role.Id', false)">No</span>
                            </span>
                            <span id="deleteSpan_@role.Id">
                                <span class="btn btn-danger"
                                   onclick="confirmDelete('@role.Id', true)">Delete</span>
                            </span>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    No roles created yet
                </div>
                <div class="card-body">
                    <h5 class="card-title">
                        Use the button below to create a role
                    </h5>
                    <a class="btn btn-primary" style="width:auto"
                       asp-controller="administration" asp-action="CreateRole">
                        Create Role
                    </a>
                </div>
            </div>
        }
    </div>
    <div class="col-lg-2">
    </div>
</div>

        @section Scripts{
            <script src="~/js/site.js"></script>
        }
