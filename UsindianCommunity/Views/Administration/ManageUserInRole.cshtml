@model List<UserRoleViewModel>
@{
    ViewBag.Title = "Add-Rmove User From Role";
    ViewBag.Area = ViewBag.Area;
}
@{
    var roleId = ViewBag.roleId;
}
<div class="row">
    <div class="mb-5  col-md-1 d-none d-md-block">
        <main role="main">

        </main>
    </div>

    <div class="container border border-dark p-3 mb-5 col-md-10">
        <h1>List Users</h1>

        <form method="post" asp-route-RoleId="@roleId" asp-route-AreaName="@ViewBag.Area">
            <div class="card">
                <div class="card-header">
                    <h2>Add or remove users from this role</h2>
                </div>
                <div class="card-body">
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <div class="form-check m-1">
                            <input type="hidden" asp-for="@Model[i].UserId" />
                            <input type="hidden" asp-for="@Model[i].UserName" />
                            <input asp-for="@Model[i].IsSelected" class="form-check-input" />
                            <label class="form-check-label" asp-for="@Model[i].IsSelected">
                                @Model[i].UserName
                            </label>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <input type="submit" value="Update" class="btn btn-primary"
                           style="width:auto" />
                    <a asp-action="EditRole" asp-controller="Administration" asp-route-id="@roleId" asp-route-AreaName=@ViewBag.Area  class="btn btn-primary" style="width:auto">Cancel</a>
                </div>
            </div>
        </form>
    </div>
        <div class="mb-5  col-md-1 d-none d-md-block">
            <main role="main">

            </main>
        </div>
</div>