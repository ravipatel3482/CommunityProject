@model PaginatedList<ApplicationUser>
@{
    ViewBag.Title = "All Users";
    ViewBag.Area = ViewBag.Area;
    TempData["Area"] = ViewBag.Area;
}
<div class="row">
    <div class="col-lg-4">

    </div>
    <div class="container col-lg-4">
        <h1 class="text-center">All Users</h1>
        @if (Model.Any())
        {
            <div class="row mb-3 ml-0">
                @*<div class="col-md-8">*@
                <form asp-area="" asp-controller="Administration" asp-action="ListUsers" method="get">
                    <p>
                        <span class="float-left">
                            <input type="text" title="Enetr UserName Fro Search" name="searchString" placeholder="search User Using  First Name Or Last Name Or Email"
                                   value="@ViewBag.UserName" class="form-control" style="width:25.5em" />
                        </span>

                        <span class="ml-lg-2">
                            <button class="btn btn-outline-info" type="submit" style="width:auto">Search</button>
                        </span>
                    </p>
                </form>
                @*</div>
                <div class="col-md-9">*@
                <span class="ml-auto mr-3">
                    <a asp-area="" asp-action="Register" asp-controller="Account" asp-route-AreaName="@ViewBag.Area" class="btn btn-primary mb-3" style="width:auto">
                        Add new user
                    </a>
                </span>
                @*</div>*@
            </div>
            <nav aria-label="Products navigation example">
                <vc:pager paging-list="@Model" />
            </nav>
            foreach (var user in Model)
            {
                <div class="card mb-3">
                    <div class="card-header">
                        User Id : @user.Id
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@user.UserName</h5>
                    </div>
                    <div class="card-footer">


                        <form method="post" asp-area="" asp-controller="Administration" asp-action="DeleteUser" asp-route-id="@user.Id" asp-route-AreaName="@ViewBag.Area">
                            <a asp-area="" asp-controller="Administration" asp-action="EditUser" asp-route-Id=@user.Id asp-route-AreaName="@ViewBag.Area" class="btn btn-primary">Edit</a>
                            @if (User.Identity.Name != user.UserName)
                            {


                                <span id="confirmDeleteSpan_@user.Id" style="display:none">
                                    <span>Are you sure you want to delete?</span>
                                    <button type="submit" class="btn btn-danger">Yes</button>
                                    <a href="#" class="btn btn-primary"
                                       onclick="confirmDelete('@user.Id', false)">No</a>
                                </span>

                                <span id="deleteSpan_@user.Id">
                                    <a class="btn btn-danger"
                                       onclick="confirmDelete('@user.Id', true)">Delete</a>
                                </span>
                            }
                        </form>
                    </div>
                </div>
            }

            <vc:pager paging-list="@Model" />

            var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
            var nextDisabled = !Model.HasNextPage ? "disabled" : "";
            <div class="row float-right">
                <a asp-action="ListUsers"
                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   class="btn btn-default @prevDisabled">
                    Previous
                </a>
                <a asp-action="ListUsers"
                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                   asp-route-currentFilter="@ViewData["CurrentFilter"]"
                   class="btn btn-default @nextDisabled">
                    Next
                </a>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    No users created yet
                </div>
                <div class="card-body">
                    <h5 class="card-title">
                        Use the button below to create a user
                    </h5>
                    <a class="btn btn-primary" style="width:auto" asp-controller="Account" asp-action="Register">
                        Add new user
                    </a>
                </div>
            </div>
        }
    </div>
    <div class="col-lg-4">

    </div>
</div>





    @section Scripts{

        <script src="~/js/site.js"></script>
    }

