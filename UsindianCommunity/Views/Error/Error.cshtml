@{ 
    ViewBag.Title =ViewBag.Title ?? "Error";
    string Area = ViewBag.Area ??  string.Empty;
    TempData["Area"] = Area;
 }
<div class="row">
    <div class="col-mb-5 col-md-2 d-none d-md-block" ></div>
    <div class="col-mb-5 col-md-8">

    @if (ViewBag.ErrorTitle == null)
    {

        <h3>
            An occured while processing your request.
            The support team is notified and we are working on the fix
        </h3>
        <h5>Contact To Admin</h5>
    }
    else
    {
        <h1 class="text-danger">@ViewBag.ErrorTitle</h1>
        <h6 class="text-danger">@ViewBag.ErrorMessage</h6>
    }
    </div>
    <div class="col-mb-5 col-md-2 d-none d-md-block"></div>
</div>