@{
    ViewBag.Title = "Not Found";
    string Area = ViewBag.Area != null ? ViewBag.Area : string.Empty;
    TempData["Area"] = Area;
}
<div class="Row">
    <div class="col-md-3">

    </div>
    <div class=" container col-md-6 "  >
        <h1>@ViewBag.ErrorMessage</h1>

        <a asp-action="index" asp-controller="Home" asp-area="@Area">            
            <img src="~/images/404NotFound.jpg" />
        </a>
    </div>
    <div class="Col-md-3">

    </div>
</div>
